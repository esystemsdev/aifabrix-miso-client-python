{
  "key": "miso-test",
  "displayName": "Miso Test",
  "description": "miso test application",
  "type": "webapp",
  "version": "1.0.0",
  "image": "myacr.azurecr.io/miso-test:latest",
  "registryMode": "acr",
  "port": 8083,
  "requiresDatabase": false,
  "requiresRedis": false,
  "requiresStorage": false,
  "databases": [],
  "configuration": [
    {
      "name": "NODE_ENV",
      "value": "development",
      "location": "variable",
      "required": false
    },
    {
      "name": "PORT",
      "value": "3083",
      "location": "variable",
      "required": false
    },
    {
      "name": "APP_NAME",
      "value": "miso-test",
      "location": "variable",
      "required": false
    },
    {
      "name": "LOG_LEVEL",
      "value": "info",
      "location": "variable",
      "required": false
    },
    {
      "name": "MISO_LOG_LEVEL",
      "value": "info",
      "location": "variable",
      "required": false
    },
    {
      "name": "MISO_CONTROLLER_URL",
      "value": "http://miso-controller:3000",
      "location": "variable",
      "required": false
    },
    {
      "name": "MISO_CLIENTID",
      "value": "miso-test-client-idKeyVault",
      "location": "keyvault",
      "required": true
    },
    {
      "name": "MISO_CLIENTSECRET",
      "value": "miso-test-client-secretKeyVault",
      "location": "keyvault",
      "required": true
    },
    {
      "name": "MISO_WEB_SERVER_URL",
      "value": "http://localhost:3100",
      "location": "variable",
      "required": false
    },
    {
      "name": "MISO_ALLOWED_ORIGINS",
      "value": "http://localhost:3083,http://localhost:*",
      "location": "variable",
      "required": false
    },
    {
      "name": "ENCRYPTION_KEY",
      "value": "secrets-encryptionKeyVault",
      "location": "keyvault",
      "required": true
    },
    {
      "name": "API_KEY",
      "value": "miso-controller-api-key-secretKeyVault",
      "location": "keyvault",
      "required": true
    },
    {
      "name": "REDIS_URL",
      "value": "redis-url",
      "location": "keyvault",
      "required": true
    },
    {
      "name": "REDIS_HOST",
      "value": "redis",
      "location": "variable",
      "required": false
    },
    {
      "name": "REDIS_PORT",
      "value": "6379",
      "location": "variable",
      "required": false
    },
    {
      "name": "REDIS_PASSWORD",
      "value": "redis-passwordKeyVault",
      "location": "keyvault",
      "required": true
    }
  ],
  "healthCheck": {
    "path": "/health",
    "interval": 30
  },
  "authentication": {
    "enableSSO": true,
    "type": "azure",
    "requiredRoles": [
      "aifabrix-user"
    ]
  },
  "roles": [
    {
      "name": "AI Fabrix Admin",
      "value": "aifabrix-admin",
      "description": "Full access to all application features and configurations"
    },
    {
      "name": "AI Fabrix User",
      "value": "aifabrix-user",
      "description": "Basic user access to the application"
    },
    {
      "name": "AI Fabrix Developer",
      "value": "aifabrix-developer",
      "description": "Developer access for testing and debugging"
    }
  ],
  "permissions": [
    {
      "name": "miso-test:read",
      "roles": [
        "aifabrix-user",
        "aifabrix-admin",
        "aifabrix-developer"
      ],
      "description": "Read access to application data"
    },
    {
      "name": "miso-test:write",
      "roles": [
        "aifabrix-admin",
        "aifabrix-developer"
      ],
      "description": "Create and edit application data"
    },
    {
      "name": "miso-test:delete",
      "roles": [
        "aifabrix-admin"
      ],
      "description": "Delete application data"
    },
    {
      "name": "miso-test:admin",
      "roles": [
        "aifabrix-admin"
      ],
      "description": "Administrative access to application configuration"
    }
  ],
  "build": {
    "envOutputPath": "../../.env"
  }
}